# Example Terraform Variables
# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored to keep sensitive data out of version control

# Email address for CloudFront monitoring alerts
alert_email = "your-email@example.com"

# Base64-encoded Basic Auth credentials for gallery.vitraigabor.eu
# Generate with: echo -n "username:password" | base64
gallery_auth_credentials = ""