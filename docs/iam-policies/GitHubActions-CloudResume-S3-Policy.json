{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListBucket",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::vitraiaws-cloud-resume-challenge",
                "arn:aws:s3:::vitraiaws-ik-website",
                "arn:aws:s3:::vitraiaws-photos-backup-thumbnails"
            ]
        },
        {
            "Sid": "ManageWebsiteBucketObjects",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:PutObjectAcl"
            ],
            "Resource": [
                "arn:aws:s3:::vitraiaws-cloud-resume-challenge/*",
                "arn:aws:s3:::vitraiaws-ik-website/*"
            ]
        },
        {
            "Sid": "ManageGalleryBucketObjects",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject"
            ],
            "Resource": "arn:aws:s3:::vitraiaws-photos-backup-thumbnails/*"
        }
    ]
}
